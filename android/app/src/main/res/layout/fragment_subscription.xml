<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@color/background">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Active Subscription Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_active_sub"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:visibility="gone" android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp"
                app:cardBackgroundColor="#EEF5FF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Active Plan" android:textSize="11sp" android:textColor="@color/brand_primary"
                        android:textStyle="bold" android:letterSpacing="0.1" />
                    <TextView android:id="@+id/tv_active_plan"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginTop="4dp" />
                    <TextView android:id="@+id/tv_active_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ACTIVE" android:textSize="12sp" android:textColor="@color/green_500"
                        android:layout_marginTop="4dp" />
                    <TextView android:id="@+id/tv_active_expiry"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="13sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                    <TextView android:id="@+id/tv_active_devices"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="13sp" android:textColor="@color/brand_primary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- License Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_license"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:visibility="gone" android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔑 License Key" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                    <TextView android:id="@+id/tv_license_key"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="—" android:textSize="15sp" android:fontFamily="monospace"
                        android:textColor="@color/text_primary" android:layout_marginTop="10dp"
                        android:background="@color/background" android:padding="12dp" />
                    <TextView android:id="@+id/tv_license_plan"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="13sp" android:textColor="@color/brand_primary"
                        android:layout_marginTop="8dp" />
                    <TextView android:id="@+id/tv_license_expiry"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="13sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                    <TextView android:id="@+id/tv_license_bound"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy_license"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:layout_marginTop="12dp" android:text="📋 Copy License Key"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Plans header -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Choose a Plan" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/text_primary" android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_plans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WiFiExtender" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_600</item>
        <item name="colorPrimaryVariant">@color/brand_700</item>
        <item name="colorSecondary">@color/signal_500</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.WiFiExtender.Splash" parent="Theme.WiFiExtender">
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
        <item name="android:statusBarColor">@color/brand_700</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
